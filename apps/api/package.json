{
  "name": "@budgetapp/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pkill -f 'tsx watch src/index.ts' 2>/dev/null; fuser -k 3000/tcp 2>/dev/null; sh -c 'set -a; . ./.env; set +a; tsx watch src/index.ts'",
    "build": "tsc --noEmit && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@budgetapp/db": "*",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^8.1.1",
    "bcryptjs": "^3.0.3",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.14.0",
    "@typescript-eslint/parser": "^7.14.0",
    "eslint": "^8.57.0",
    "tsx": "^4.15.6",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
